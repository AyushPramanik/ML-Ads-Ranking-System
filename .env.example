# ---------------------------------------------------------------------------
# Environment configuration for the ML Ads Ranking System.
# Copy to `.env` and adjust as needed: `cp .env.example .env`
# Both the Go ranking service and docker-compose read these values.
# ---------------------------------------------------------------------------

# ---- Ranking service (Go) ----
RANKING_HTTP_ADDR=:8080
RANKING_LOG_LEVEL=info
RANKING_LOG_FORMAT=json
# Path to the exported model produced by the Python training pipeline.
RANKING_MODEL_PATH=/artifacts/model.json
RANKING_FEATURE_SPEC_PATH=/artifacts/feature_spec.json
# Read/write timeouts and graceful-shutdown grace period (Go duration strings).
RANKING_READ_TIMEOUT=5s
RANKING_WRITE_TIMEOUT=10s
RANKING_SHUTDOWN_TIMEOUT=15s

# ---- PostgreSQL (ad metadata & campaigns) ----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=ads
POSTGRES_PASSWORD=ads
POSTGRES_DB=ads_ranking
# DSN consumed by the Go service. Overrides the discrete fields above if set.
RANKING_POSTGRES_DSN=postgres://ads:ads@postgres:5432/ads_ranking?sslmode=disable

# ---- Redis (feature cache) ----
REDIS_HOST=redis
REDIS_PORT=6379
RANKING_REDIS_ADDR=redis:6379
RANKING_FEATURE_CACHE_TTL=300s

# ---- ML training pipeline (Python) ----
ADS_ML_DATA_DIR=./data
ADS_ML_ARTIFACTS_DIR=./artifacts
ADS_ML_RANDOM_SEED=42
